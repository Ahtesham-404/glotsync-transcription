# GlotSync AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
ALLOWED_ORIGINS=https://glotsync.online,https://www.glotsync.online

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://glotsync:your_db_password@localhost:5432/glotsync

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Used for both Amazon S3 (file storage) and Amazon Transcribe (transcription).
# The IAM user needs: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:HeadObject
#                     transcribe:StartTranscriptionJob, transcribe:GetTranscriptionJob
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=glotsync-files
S3_SIGNED_URL_EXPIRY=900

# ── Amazon Transcribe ─────────────────────────────────────────────────────────
# BCP-47 language code for transcription jobs.
# Examples: en-US, en-GB, es-US, fr-FR, de-DE, hi-IN, ar-SA, zh-CN, ja-JP
# Full list: https://docs.aws.amazon.com/transcribe/latest/dg/supported-languages.html
TRANSCRIBE_LANGUAGE_CODE=en-US

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=glotsync-199c1
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/glotsync/firebase-service-account.json

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_HOUR=20
