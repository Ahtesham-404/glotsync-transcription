# Application
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_ORIGINS=https://glotsync.online,https://www.glotsync.online

# Database
DATABASE_URL=postgresql+asyncpg://glotsync:password@localhost:5432/glotsync

# Amazon S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=glotsync-files
S3_SIGNED_URL_EXPIRY=900

# Firebase Admin SDK
FIREBASE_PROJECT_ID=glotsync-199c1
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/glotsync/firebase-service-account.json

# Upload limits
MAX_FILE_SIZE_MB=500

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_HOUR=20

# Transcription (placeholder — swap for real provider)
TRANSCRIPTION_PROVIDER=openai_whisper
OPENAI_API_KEY=sk-your-openai-key
